{
  "name": "typographics",
  "version": "4.0.0",
  "description": "typographics provides flexible and adaptive styles for typography on web pages. This package allows you to automate the resizing of fonts based on screen width, ensuring good readability on any device.",
  "type": "module",
  "author": "ux-ui.pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ux-ui-pro/typographics.git"
  },
  "bugs": {
    "url": "https://github.com/ux-ui-pro/typographics/issues"
  },
  "homepage": "https://github.com/ux-ui-pro/typographics",
  "sideEffects": [
    "dist/*.css"
  ],
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "style": "./dist/index.css",
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "vite build",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:fix:css": "stylelint \"src/**/*.scss\" --fix",
    "test:smoke": "node --test \"tests/**/*.js\"",
    "pack:check": "npm pack --dry-run && publint",
    "verify": "npm run lint:css && npm run build && npm run test:smoke && npm run pack:check",
    "prepublishOnly": "npm run clean && npm run verify"
  },
  "browserslist": [
    ">=0.5%",
    "last 2 versions",
    "not dead"
  ],
  "devDependencies": {
    "lightningcss": "1.30.2",
    "publint": "^0.3.21",
    "rimraf": "6.1.3",
    "sass": "1.97.0",
    "stylelint": "16.25.0",
    "stylelint-config-standard-scss": "16.0.0",
    "vite": "7.3.0"
  },
  "keywords": [
    "typography",
    "responsive",
    "adaptive",
    "font",
    "size",
    "scaling",
    "variables",
    "sass",
    "scss",
    "css",
    "viewport",
    "clamp",
    "dynamic",
    "balance",
    "smoothing",
    "rendering",
    "optimization",
    "design",
    "modern",
    "utilities",
    "accessibility"
  ]
}
